# jq — command-line JSON processor (packaged by Homebrew as `jq`)
NAME jq
VERSION 1.7.1
DESCRIPTION Lightweight and flexible command-line JSON processor
LICENSE MIT
URL https://jqlang.github.io/jq/
FETCH https://github.com/jqlang/jq/releases/download/jq-${PKGOCI_VERSION}/jq-${PKGOCI_VERSION}.tar.gz 478c9ca129fd2e3443fe27314b455e211e0d8c60bc8ff7df703873deeee580c2
SOURCE
RUN ./configure --disable-maintainer-mode \
    --with-oniguruma=builtin --prefix=$PWD/out
RUN make -j4 install
TEST echo '{"a":1}' | ./out/bin/jq .a
OUTPUT ./out
